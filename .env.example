# Local development
PORT=3000
DATABASE_URL=postgres://flowdesk:flowdesk_password@localhost:5432/flowdesk
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=tasks_vectors
VECTOR_SIZE=384

# Optional for Vercel/serverless. Set true if you do not want Qdrant reindex on cold start.
SKIP_QDRANT_REINDEX=false
